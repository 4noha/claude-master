[38;2;255;255;255m⏺[1C[39m既存の実装を把握しました。[38;2;153;204;255mpty_proxy.py[1C[39mが既に[1C[38;2;153;204;255musage_percent[1C[39mと[1C[38;2;153;204;255mreset_time[1C[39mを[1C[38;2;153;204;255m<pid>.status.json[39m
[2Cに書き出しており、[38;2;153;204;255mmonitor.py[1C[39mがそれを読んでいます。あとは「その数値をトリガーに行動する」層が欠けているだけです。

[2C---
[2C[1m設計[22m

[2C[1m全体フロー[22m

[2Cpty_proxy.py
[4C→[1C<pid>.status.json[1Cに[1Cusage_percent[1C/[1Creset_time[1Cを書き出し済み

[2Cmonitor.py[1Crun_loop()
[4C└─[1CLimitWatcher.check(status)[2C←[1C新規
[9C├─[1CAPPROACHING[1C(≥80%)[2C→[1Ctmux[1Cウィンドウ名に[1C⚠[1C表示
[9C├─[1CINTERRUPT[3C(≥90%)[2C→[1CClaude[1Cセッションに[1CESC[1C+[1Cメッセージ注入
[9C└─[1CREACHED[4C(100%)[2C→[1C同上[1C+[1CResumeScheduler.schedule(reset_datetime)

[2CResumeScheduler
[4C├─[1Cmonitor[1C内ループで管理[1C(シンプル・デフォルト)
[4C└─[1Claunchd[1Cplist[1C書き出し[2C(monitor[1C再起動耐性)
[10C→[1Creset[1C時刻に[1C`socket_client.py`[1C経由でセッション再開メッセージ送信

[2C---
[2C[1m新規モジュール:[1C[38;2;153;204;255mlimit_watcher.py[22m[39m

[2C[90m@dataclass[39m
[2C[34mclass[1C[39mLimitEvent:
[6Csession_key:[1C[36mstr[39m
[6Clevel:[1C[36m[2mLiteral[22m[39m[[31m"approaching"[39m,[1C[31m"interrupt"[39m,[1C[31m"reached"[39m]
[6Cusage_percent:[1C[36mint[39m
[6Creset_time_str:[1C[36mstr[3C[32m#[1C"8:30[1Cpm"[39m
[6Creset_tz:[1C[36mstr[9C[32m#[1C"UTC+9"[39m

[2C[34mclass[1C[39mLimitWatcher:
[6CAPPROACHING_THRESHOLD[1C=[1C[32m80[39m
[6CINTERRUPT_THRESHOLD[3C=[1C[32m90[39m

[6C[34mdef[33m [39m__init__(self):
[10Cself._notified:[1C[36mdict[39m[[36mstr[39m,[1C[36mstr[39m][1C=[1C{}[2C[32m#[1Ckey[1C→[1Clast[1Clevel[1Cnotified[39m

[6C[34mdef[33m [39mcheck(self,[1Ckey:[1C[36mstr[33m,[1Cstatus:[1C[36mdict[39m)[1C->[1CLimitEvent[1C|[1C[34mNone[33m:[39m
[10Cpct[1C=[1Cstatus.get([31m"usage_percent"[39m)
[10C[34mif[1C[39mpct[1C[34mis[1CNone[39m:
[14C[34mreturn[1CNone[39m
[10Clevel[1C=[1C(
[14C[31m"reached"[4C[34mif[1C[39mpct[1C>=[1C[32m100[1C[34melse[39m
[14C[31m"interrupt"[2C[34mif[1C[39mpct[1C>=[1Cself.INTERRUPT_THRESHOLD[1C[34melse[39m
[14C[31m"approaching"[1C[34mif[1C[39mpct[1C>=[1Cself.APPROACHING_THRESHOLD[1C[34melse[39m
[14C[34mNone[39m
[10C)
[10C[34mif[1C[39mlevel[1C[34mand[1C[39mself._notified.get(key)[1C!=[1Clevel:
[14Cself._notified[key][1C=[1Clevel
[14C[34mreturn[1C[39mLimitEvent(key,[1Clevel,[1Cpct,
[32Cstatus.get([31m"reset_time"[39m,[31m""[39m),[1Cstatus.get([31m"reset_tz"[39m,[31m""[39m))
[10C[34mreturn[1CNone[39m

[2C[1mポイント:[1C[22m同じ[1Clevel[1Cは1回だけ発火。usage[1Cが下がった場合（プラン更新後）は自動リセット。

[2C---
[2C[1m新規モジュール:[1C[38;2;153;204;255mresume_scheduler.py[22m[39m

[2C[34mclass[1C[39mResumeScheduler:
[6C[34mdef[33m [39mparse_reset_datetime(self,[1Ctime_str:[1C[36mstr[33m,[1Ctz_str:[1C[36mstr[39m)[1C->[1Cdatetime[1C|[1C[34mNone[33m:[39m
[10C[32m#[1C"8:30[1Cpm"[1C+[1C"UTC+9"[1C→[1C今日または明日の[1Caware[1Cdatetime[39m
[10C...

[6C[34mdef[33m [39mschedule(self,[1Csession_key:[1C[36mstr[33m,[1Creset_at:[1Cdatetime,[1Csocket_path:[1C[36mstr[39m)[1C->[1C[34mNone[33m:[39m
[10C[32m#[1C方式A:[1Cmonitor[1Cループ内で管理（デフォルト）[39m
[10Cself._pending[session_key][1C=[1C(reset_at,[1Csocket_path)

[6C[34mdef[33m [39mdue(self,[1Cnow:[1Cdatetime)[1C->[1C[36mlist[33m[[36mstr[33m]:[39m
[10C[31m"""reset_at[1Cを過ぎたセッション[1Ckey[1Cを返し[1Cpending[1Cから削除"""[39m
[10C...

[6C[32m#[1C方式B:[1Claunchd[1Cplist[1C(monitor[1C再起動耐性が必要な場合)[39m
[6C[34mdef[33m [39mschedule_launchd(self,[1Csession_key:[1C[36mstr[33m,[1Creset_at:[1Cdatetime,[1Ccmd:[1C[36mlist[33m[[36mstr[33m][39m)[1C->[1C[34mNone[33m:[39m
[10Cplist[1C=[1C_build_plist(session_key,[1Creset_at,[1Ccmd)
[10Cpath[1C=[1CPath.home()[1C/[1C[31m"Library/LaunchAgents"[1C[39m/[1C[31mf"com.claude-master.resume.[39m{session_key}.plist"
[10Cpath.write_text(plist)
[10Csubprocess.run([[31m"launchctl"[39m,[1C[31m"load"[39m,[1C[36mstr[39m(path)],[1Ccheck=[34mTrue[39m)

[2C---
[2C[38;2;153;204;255m[1mmonitor.py[1Crun_loop[39m への統合[22m

[2C[34masync[1Cdef[33m [39mrun_loop(manager:[1CTmuxManager)[1C->[1C[34mNone[33m:[39m
[6Cwatcher[3C=[1CLimitWatcher()
[6Cscheduler[1C=[1CResumeScheduler()
[6Cknown:[1C[36mdict[39m[[36mstr[39m,[1CClaudeSession][1C=[1C{}

[6C[34mwhile[1CTrue[39m:
[10Ccurrent[1C=[1C{s.key:[1Cs[1C[34mfor[1C[39ms[1C[34min[1C[39mscan()}
[10C[32m#[1C...[1C既存のセッション追加/削除処理[1C...[39m

[10C[32m#[1C---[1C上限監視[1C(新規)[1C---[39m
[10C[34mfor[1C[39mkey,[1Csession[1C[34min[1C[39mcurrent.items():
[14Cstatus[1C=[1C_read_session_status(session.pid)
[14Cevent[2C=[1Cwatcher.check(key,[1Cstatus)
[14C[34mif[1C[39mevent:
[18C_handle_limit_event(event,[1Csession,[1Cmanager,[1Cscheduler)

[10C[32m#[1C---[1Cリセット待ち再開[1C(新規)[1C---[39m
[10C[34mfor[1C[39mkey[1C[34min[1C[39mscheduler.due(datetime.now()):
[14Csession[1C=[1Ccurrent.get(key)
[14C[34mif[1C[39msession:
[18C_resume_session(session)

[10Cknown[1C=[1Ccurrent
[10C_write_status([36mlist[39m(current.values()),[1Cmanager)
[10C[34mawait[1C[39masyncio.sleep(POLL_INTERVAL)

[2C---
[2C[1mセッション割り込みアクション[1C[38;2;153;204;255m_handle_limit_event[22m[39m

[2Clevel[1C=[1Capproaching
[4C→[1Ctmux[1Crename-window:[1C"myproject[1C[⚠80%]"
[4C→[1Cログ出力のみ（作業は続行）

[2Clevel[1C=[1Cinterrupt
[4C→[1Csocket_client[1C経由で[1CESC[1C送信（生成中断）
[4C→[1C続けて以下のメッセージをセッションに注入:
[6C"⚠[1CUsage[1Climit[1Cat[1C90%.[1CReset:[1C8:30[1Cpm[1CJST.
[7C現在の作業状態を要約して、続きの指示書を残してください。"
[4C→[1CResumeScheduler.schedule(reset_at,[1Csocket_path)

[2Clevel[1C=[1Creached
[4C→[1Cinterrupt[1Cと同じ動作
[4C→[1Ctmux[1Crename-window:[1C"myproject[1C[PAUSED]"

[2CESC[1C+[1Cメッセージ注入は[1C[38;2;153;204;255msocket_client.py[1C[39mの既存[1CAPI[1Cで実現可能（[38;2;153;204;255msend_input[39m）。

[2C---
[2C[1m再開アクション[1C[38;2;153;204;255m_resume_session[22m[39m

[2Creset_at[1C到達時:
[4C→[1Csocket_client[1C経由で以下を送信:
[6C"プラン制限がリセットされました。中断前の作業を再開してください。"
[4C→[1Ctmux[1Crename-window[1Cを[1C"[⚠]"[1C表示から元に戻す
[4C→[1Cスケジュールから削除

[2C---
[2C[1m実装順序[22m

[2C1.[1C[38;2;153;204;255mlimit_watcher.py[1C[39m—[1Cthreshold[1C判定とイベント生成（独立して単体テスト可）
[2C2.[1C[38;2;153;204;255mresume_scheduler.py[1C[39m—[1Creset_time[1Cパース[1C+[1Cpending[1C管理（方式A[1Cから始める）
[2C3.[1C[38;2;153;204;255mmonitor.py[1C[39m—[1C[38;2;153;204;255mrun_loop[1C[39mへの統合と[1C[38;2;153;204;255m_handle_limit_event[1C[39m/[1C[38;2;153;204;255m_resume_session[39m
[2C4.[1Cオプション:[1Claunchd[1C方式B（monitor[1Cプロセスが落ちても再開できる堅牢版）

